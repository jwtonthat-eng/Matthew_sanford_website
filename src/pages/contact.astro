---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Matt Sanford" screenLabel="06 Contact" active={null}>
  <section class="pagehead">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Tell me about your body. I'll write back.</h1>
      <p class="lede">
        One short form. One real human reading it. Replies usually within two
        days.
      </p>
    </div>
  </section>

  <section>
    <div class="container" style="display:grid; grid-template-columns: 1.1fr 1fr; gap: 80px; align-items:start;">
      <form class="form" style="max-width: none;">
        <div class="field">
          <label>Your name</label>
          <input type="text" placeholder="First and last" />
        </div>
        <div class="field">
          <label>Email</label>
          <input type="email" placeholder="you@somewhere" />
        </div>
        <div class="field">
          <label>What brings you here?</label>
          <textarea placeholder="A few sentences. What's not working, what you'd like to do, anything I should know going in. No essays — we'll talk it through."></textarea>
        </div>
        <div class="field">
          <label>How did you find me?</label>
          <input type="text" placeholder="Optional" />
        </div>
        <button type="button" class="btn btn-primary" style="justify-self:start; margin-top: 8px;">
          Send <span class="arrow">→</span>
        </button>
        <p class="fineprint" style="color: var(--granite); margin-top: 8px;">
          By sending this you're agreeing to a single, human reply. No mailing
          list, no auto-sequences.
        </p>
      </form>

      <aside>
        <h3 style="font-family: var(--serif); font-size: 26px;">In the meantime</h3>
        <dl style="display:grid; gap: 24px; margin-top: 24px;">
          <div>
            <dt style="font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--granite);">Email</dt>
            <dd style="margin: 4px 0 0; font-family: var(--serif); font-size: 22px; color: var(--forest-deep);">
              <a href="mailto:matt@example.com">matt@example.com</a>
            </dd>
          </div>
          <div>
            <dt style="font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--granite);">Phone</dt>
            <dd style="margin: 4px 0 0; font-family: var(--serif); font-size: 22px; color: var(--forest-deep);">(978) 555-0142</dd>
          </div>
          <div>
            <dt style="font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--granite);">Gym</dt>
            <dd style="margin: 4px 0 0; font-family: var(--serif); font-size: 18px; color: var(--ink);">
              North Shore Strength &amp; Movement<br />140 Cabot St, Beverly, MA 01915
            </dd>
          </div>
          <div>
            <dt style="font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--granite);">Hours</dt>
            <dd style="margin: 4px 0 0; font-family: var(--serif); font-size: 18px; color: var(--ink);">
              By appointment only<br /><span style="color: var(--granite);">Tue–Sat, mornings</span>
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section>
    <div class="container">
      <div style="aspect-ratio: 16/7; background: var(--paper-warm); border: 1px solid var(--rule); position: relative; overflow: hidden;">
        <div style="position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=2000&q=80&auto=format&fit=crop'); background-size: cover; background-position: center; opacity: 0.55;"></div>
        <div style="position: absolute; inset: 0; display: grid; place-items: center; text-align:center;">
          <div>
            <span class="eyebrow" style="background: var(--paper); padding: 6px 12px; border-radius: 999px;">Map placeholder</span>
            <h3 style="margin-top: 18px; font-size: 32px;">North Shore Strength &amp; Movement</h3>
            <p style="color: var(--granite); margin-top: 8px;">140 Cabot St · Beverly, MA</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
